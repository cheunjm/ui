{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "develop": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "develop",
      "env": {
        "APP_ENV": "develop"
      },
      "ios": {
        "simulator": true
      }
    },
    "stage": {
      "distribution": "internal",
      "channel": "stage",
      "env": {
        "APP_ENV": "stage"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "jaemincheun@gmail.com",
        "ascAppId": "com.aramiworks.ui.storybook"
      }
    },
    "visual-test": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_ENV": "develop"
      },
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    }
  }
}
