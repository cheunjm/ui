{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "develop": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "develop",
      "env": {
        "APP_ENV": "develop"
      }
    },
    "stage": {
      "distribution": "internal",
      "channel": "stage",
      "env": {
        "APP_ENV": "stage"
      }
    },
    "master": {
      "distribution": "store",
      "channel": "master",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "master"
      }
    }
  },
  "submit": {
    "master": {
      "ios": {
        "appleId": "jaemincheun@gmail.com",
        "ascAppId": "so.arami.ui.storybook"
      }
    }
  }
}
