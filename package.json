{
  "name": "@aramiworks/ui",
  "version": "0.2.1",
  "description": "Expo-based design system — Brad Frost atomic design, MD3 interface, Tamagui internals",
  "main": "expo/AppEntry",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "src/index.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "dev:dashboard": "mprocs",
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "storybook:generate": "sb-rn-get-stories",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "storybook:web": "storybook dev -p 6006 -c .storybook --disable-telemetry",
    "storybook:build": "storybook build -c .storybook --disable-telemetry",
    "test:e2e:web": "maestro test --platform web e2e/integration/ e2e/journeys/",
    "test:e2e:ios": "maestro test --platform ios e2e/integration/ e2e/journeys/",
    "test:e2e:android": "maestro test --platform android e2e/integration/ e2e/journeys/"
  },
  "dependencies": {
    "expo-updates": "~55.0.16"
  },
  "peerDependencies": {
    "@gorhom/bottom-sheet": ">=5.0.0",
    "@react-native-community/datetimepicker": ">=8.0.0",
    "@react-native-community/slider": ">=4.0.0",
    "@tamagui/animations-react-native": ">=1.112.0",
    "@tamagui/config": ">=1.112.0",
    "@tamagui/core": ">=1.112.0",
    "@tamagui/font-inter": ">=1.112.0",
    "@tamagui/shorthands": ">=1.112.0",
    "@tamagui/themes": ">=1.112.0",
    "expo": ">=55.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.83.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-safe-area-context": ">=5.0.0",
    "react-native-svg": ">=15.0.0",
    "react-native-worklets": ">=0.7.0",
    "tamagui": ">=1.112.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
