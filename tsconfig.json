{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@storybook/react": ["./node_modules/@storybook/react-native/node_modules/@storybook/react"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".ondevice/**/*.ts", ".ondevice/**/*.tsx", ".storybook/**/*.ts", ".storybook/**/*.tsx"],
  "exclude": [".ondevice/storybook.requires.ts"]
}
